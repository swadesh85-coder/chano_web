{
  "name": "chano-web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "profile:browser-performance": "npm run build && node scripts/browser-performance-profile.mjs",
    "test:visual": "npm run build && npx vitest run src/app/visual_regression.spec.ts",
    "test:visual:update-baseline": "npm run build && node scripts/visual-regression-runner.mjs --update-baseline"
  },
  "private": true,
  "packageManager": "npm@11.8.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@fontsource-variable/noto-sans": "^5.2.8",
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.0",
    "@types/qrcode": "^1.5.6",
    "jsdom": "^28.0.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.1",
    "puppeteer": "^24.40.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
